# ─── Application ─────────────────────
NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# ─── MongoDB ──────────────────────────
MONGODB_URI=mongodb://mongo_user:mongo_password@mongodb:27017/medinote?authSource=admin

# ─── Redis ────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ─── JWT ──────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars

# ─── Email SMTP ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@medinote.borisgauty.com

# ─── Frontend ─────────────────────────
FRONTEND_URL=https://medinote.borisgauty.com
